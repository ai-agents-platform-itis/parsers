# =============================================================================
# Пример конфигурации. Скопируй в .env и заполни своими значениями:
#   cp .env.example .env
# .env в git НЕ коммитим (см. .gitignore).
# =============================================================================

# --- Telegram (получить на https://my.telegram.org -> API development tools) ---
API_ID=123456
API_HASH=your_api_hash_here
# Имя файла сессии Telethon (создастся как parser_session.session).
SESSION_NAME=parser_session

# --- Инфраструктура (по умолчанию совпадает с docker-compose) ---
DATABASE_URL=postgresql+psycopg2://parser:parser@localhost:5432/parser_db
REDIS_URL=redis://localhost:6379/0

# --- Лимит исходящих в сутки на аккаунт (Telegram: 20-30 для новых акков) ---
DAILY_OUTBOX_LIMIT=25

# --- Прокси с ротацией (Спринт 4). PROXY_ENABLED=true включает пул ---
PROXY_ENABLED=false
# Список прокси через запятую или перенос строки. Каждый — в URL-форме:
#   socks5://user:pass@host:port   http://host:port   socks5://host:port
PROXY_LIST=
# Альтернатива/дополнение: путь к файлу со списком (по одному прокси на строку).
PROXY_FILE=
# Сколько секунд «остывает» прокси после ошибки/бана (не выдаётся из пула).
PROXY_COOLDOWN_SECONDS=300
# Legacy-одиночный прокси (Спринт 1) — тоже подхватится и добавится в пул.
PROXY_TYPE=socks5
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# --- Веб-парсеры Avito / Instagram (Спринт 2) ---
# Интервалы поллинга, сек. Чаще = выше риск бана по IP/аккаунту.
AVITO_POLL_INTERVAL=300
INSTAGRAM_POLL_INTERVAL=600
# false — видимый браузер (удобно для локальной отладки селекторов).
PLAYWRIGHT_HEADLESS=true
# Таймаут загрузки страницы, мс.
PARSER_PAGE_TIMEOUT_MS=30000
# Кука sessionid залогиненного аккаунта Instagram (без неё — стена логина).
# DevTools -> Application -> Cookies -> instagram.com -> sessionid.
INSTAGRAM_SESSIONID=
# Сколько дней помним обработанные объявления/комментарии (дедуп в Redis).
SEEN_ITEMS_TTL_DAYS=7

# --- AmoCRM (Спринт 3): передача горячих лидов ---
# Базовый URL аккаунта и долгосрочный токен (Настройки -> Интеграции ->
# своя интеграция -> Ключи и доступы). Пусто = CRM-шаг пропускается.
AMOCRM_BASE_URL=
AMOCRM_ACCESS_TOKEN=
# Опционально: id воронки/этапа/ответственного для новых сделок.
AMOCRM_PIPELINE_ID=
AMOCRM_STATUS_ID=
AMOCRM_RESPONSIBLE_USER_ID=

# --- Горячие лиды (Спринт 3) ---
# Порог скоринга 0..100: score >= порога -> сделка в CRM + пинг менеджеру.
HOT_LEAD_THRESHOLD=60
# Бот-нотификатор менеджера: токен из @BotFather, chat_id — из @userinfobot
# (менеджер должен один раз нажать Start у бота). Пусто = не уведомляем.
MANAGER_BOT_TOKEN=
MANAGER_CHAT_ID=

# --- Реальная отправка в Telegram (Спринт 3) ---
# false — заглушка (лог + запись в БД). true — отправка через отдельную
# сессию Telethon; авторизуй её один раз:
#   uv run python -m parser_service.telegram.sender
TELEGRAM_SEND_ENABLED=false
# Имя файла сессии отправителя (по умолчанию <SESSION_NAME>_sender).
SENDER_SESSION_NAME=

# --- Логирование ---
LOG_LEVEL=INFO
